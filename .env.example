# Required environment variables for El Colorado application
NODE_ENV=development

# Authentication
# Required for Google OAuth and NextAuth.js
GOOGLE_CLIENT_ID="my_client_id"
GOOGLE_CLIENT_SECRET="my_client_secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_SEED_EMAIL="example@example.com"
ADMIN_SEED_PASSWORD="replace-with-a-temporary-admin-password"

# Database configuration (recommended for Vercel + Supabase)
# Runtime/app connection (pooler)
# Required for Production and Development
# sslmode=require is required for remote PostgreSQL providers that require SSL (e.g., Supabase, Heroku). Remove sslmode=require for local development if your PostgreSQL instance does not use SSL.
# ?schema=mixmart&pgbouncer=true&sslmode=require&sslaccept=accept_invalid_certs
DB_POOLER_URL="postgresql://myuser:mypassword@127.0.0.1:5420/mydb?sslmode=disable&schema=mixmart"

# Prisma CLI/migrations connection (direct/session)
# Required for Development
# sslmode=require is required for remote PostgreSQL providers that require SSL (e.g., Supabase, Heroku). Remove sslmode=require for local development if your PostgreSQL instance does not use SSL.
DB_DIRECT_URL="postgresql://myuser:mypassword@127.0.0.1:5420/mydb?sslmode=disable&schema=mixmart"

# Test database configuration
# Required for Testing
TEST_DATABASE_URL="postgresql://myuser:mypassword@localhost:5420/mydb?sslmode=disable&schema=public"
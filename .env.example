NODE_ENV=development

# Authentication
GOOGLE_CLIENT_ID="my_client_id"
GOOGLE_CLIENT_SECRET="my_client_secret"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
ADMIN_SEED_EMAIL="example@example.com"
ADMIN_SEED_PASSWORD="replace-with-a-temporary-admin-password"

# Database configuration
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="postgres"
DB_SCHEMA="mixmart"
# DB_SSLMODE="require" # Enable for remote PostgreSQL providers that require SSL.

# Test database configuration
TEST_DB_USER="myuser"
TEST_DB_PASSWORD="mypassword"
TEST_DB_HOST="localhost"
TEST_DB_PORT=5420
TEST_DB_NAME="mydb"
TEST_DB_SCHEMA="public"
